  "tracking": {
    "$type": "dimension",
    "none": {
      "$value": "0em"
    },
    "tight": {
      "$value": "-0.01em"
    },
    "wide": {
      "$value": "0.02em"
    }
  },
  "shadow": {
    "$type": "shadow",
    "xs": {
      "$value": {
        "color": "rgb(15 23 42 / 0.06)",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px"
      }
    },
    "sm": {
      "$value": {
        "color": "rgb(15 23 42 / 0.08)",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "3px",
        "spread": "0px"
      }
    },
    "md": {
      "$value": [
        {
          "color": "rgb(15 23 42 / 0.08)",
          "offsetX": "0px",
          "offsetY": "6px",
          "blur": "18px",
          "spread": "-4px"
        },
        {
          "color": "rgb(15 23 42 / 0.04)",
          "offsetX": "0px",
          "offsetY": "2px",
          "blur": "6px",
          "spread": "-2px"
        }
      ]
    },
    "lg": {
      "$value": [
        {
          "color": "rgb(15 23 42 / 0.1)",
          "offsetX": "0px",
          "offsetY": "18px",
          "blur": "44px",
          "spread": "-14px"
        },
        {
          "color": "rgb(15 23 42 / 0.06)",
          "offsetX": "0px",
          "offsetY": "8px",
          "blur": "18px",
          "spread": "-10px"
        }
      ]
    },
    "glass": {
      "$value": [
        {
          "color": "rgb(255 255 255 / 0.7)",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "1px",
          "spread": "0px",
          "inset": true
        },
        {
          "color": "rgb(15 23 42 / 0.14)",
          "offsetX": "0px",
          "offsetY": "18px",
          "blur": "44px",
          "spread": "-18px"
        }
      ]
    }
  },
  "opacity": {
    "$type": "number",
    "disabled": {
      "$value": 0.38
    },
    "muted": {
      "$value": 0.62
    },
    "scrim": {
      "$value": 0.44
    }
  },
  "duration": {
    "$type": "duration",
    "instant": {
      "$value": "0ms"
    },
    "fast": {
      "$value": "120ms"
    },
    "normal": {
      "$value": "180ms"
    },
    "slow": {
      "$value": "260ms"
    },
    "slower": {
      "$value": "420ms"
    }
  },
  "ease": {
    "$type": "cubicBezier",
    "standard": {
      "$value": [0.2, 0.8, 0.2, 1]
    },
    "out": {
      "$value": [0.16, 1, 0.3, 1]
    },
    "in": {
      "$value": [0.7, 0, 0.84, 0]
    }
  },
